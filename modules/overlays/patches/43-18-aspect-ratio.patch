From 8207c3b33cd8e7533fed7ee51d27345db3ab2e2e Mon Sep 17 00:00:00 2001
From: onelocked <onelock@mail.com>
Date: Thu, 5 Feb 2026 23:37:24 +0000
Subject: [PATCH] 43:18 aspect ratio

---
 src/widgets/edit/crop.ui           | 4 ++--
 src/widgets/edit/crop_selection.rs | 2 +-
 2 files changed, 3 insertions(+), 3 deletions(-)

diff --git a/src/widgets/edit/crop.ui b/src/widgets/edit/crop.ui
index 731784d..09b249c 100644
--- a/src/widgets/edit/crop.ui
+++ b/src/widgets/edit/crop.ui
@@ -18,7 +18,7 @@
         <attribute name="target">square</attribute>
       </item>
       <item>
-        <attribute name="label" translatable="yes">5:4</attribute>
+         <attribute name="label" translatable="yes">43:18</attribute>
         <attribute name="action">edit-crop.aspect-ratio</attribute>
         <attribute name="target">r5to4</attribute>
       </item>
@@ -142,7 +142,7 @@
                               <object class="AdwButtonContent">
                                 <property name="halign">start</property>
                                 <property name="icon-name">aspect-ratio-5to4-symbolic</property>
-                                <property name="label" translatable="yes">_5:4</property>
+                                 <property name="label" translatable="yes">_43:18</property>
                                 <property name="use-underline">true</property>
                                 <style>
                                   <class name="has-orientation" />
diff --git a/src/widgets/edit/crop_selection.rs b/src/widgets/edit/crop_selection.rs
index 94f3261..82ba78d 100644
--- a/src/widgets/edit/crop_selection.rs
+++ b/src/widgets/edit/crop_selection.rs
@@ -111,7 +111,7 @@ impl LpAspectRatio {
             Self::Free => None,
             Self::Original => None,
             Self::Square => Some((1, 1)),
-            Self::R5to4 => Some((5, 4)),
+            Self::R5to4 => Some((43, 18)),
             Self::R4to3 => Some((4, 3)),
             Self::R3to2 => Some((3, 2)),
             Self::R16to9 => Some((16, 9)),
